{
  "description": "Automatically logs session cost data on exit",
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-logger.js\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
